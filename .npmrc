# Disable provenance attestation for publishing.
# Reason: the bundled npm in this environment is missing the `sigstore`
# module (libnpmpublish requires it unconditionally), so generating
# provenance fails. Remove this once npm is fixed / on a machine whose
# npm ships sigstore, if you want signed provenance on the package.
provenance=false

# Scoped packages default to private on npm; publish as public so a
# free account can release @gdwhisper/fork-it (avoids E402 Payment Required).
access=public
